{
  "name": "@acoyfellow/cloudterm",
  "version": "0.0.1",
  "description": "Web terminal emulator. DOM-rendered. Built on @chenglou/pretext.",
  "author": "Jordan Coeyman <jordan@coey.dev>",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/acoyfellow/cloudterm.git"
  },
  "homepage": "https://github.com/acoyfellow/cloudterm",
  "bugs": "https://github.com/acoyfellow/cloudterm/issues",
  "keywords": [
    "terminal",
    "ansi",
    "xterm",
    "dom",
    "pretext",
    "emulator"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.5"
  },
  "devDependencies": {
    "tsdown": "^0.17.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false
}
